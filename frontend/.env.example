# ── Supabase (REQUIRED) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Upstash Redis (REQUIRED for caching + rate limiting) ──
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ── AI Content Generation (REQUIRED for What-If) ──
GEMINI_API_KEY=your-gemini-api-key

# ── Cron Security (REQUIRED in production) ──
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret

# ── Optional ──
NEXT_PUBLIC_SITE_URL=https://your-domain.com
POLLINATIONS_API_KEY=your-pollinations-key
THREADS_ACCESS_TOKEN=your-threads-token
